{
  "name": "engineer-test-project",
  "version": "1.0.0",
  "description": "",
  "main": "engineer.config.js",
  "scripts": {
    "set-dev": "npx ncp ./__env__/dev ./prisma/.env && npx ncp ./__env__/verceldev ./vercel.json",
    "set-prod": "npx ncp ./__env__/prod ./prisma/.env && npx ncp ./__env__/vercelprod ./vercel.json",
    "set-qa": "npx ncp ./__env__/qa ./prisma/.env && npx ncp ./__env__/vercelqa ./vercel.json",
    "prisma-generate": "npx prisma generate",
    "dev": "nodemon index.js",
    "predev": "npm run set-dev",
    "qa": "nodemon src",
    "preqa": "npm run set-qa",
    "prod": "nodemon src",
    "preprod": "npm run set-prod",
    "test": "echo \"Error: no test specified\" && exit 1",
    "seed": "node __seed__",
    "premigrate": "npm run prisma-generate",
    "migrate": "npx prisma migrate save --experimental && npx prisma migrate up --experimental",
    "postmigrate": "npm run seed raw all",
    "engineer": "node node_modules/@ericksatelite/engineer/src/main"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@prisma/cli": "2.2.0",
    "@prisma/client": "2.2.0",
    "axios": "^0.20.0",
    "body-parser": "^1.19.0",
    "cors": "^2.8.5",
    "device-detector-js": "^2.2.1",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "fs-jetpack": "^3.1.0",
    "generate-password": "^1.5.1",
    "handlebars": "^4.7.6",
    "jsonwebtoken": "^8.5.1",
    "jwk-to-pem": "^2.0.4",
    "lodash.groupby": "^4.6.0",
    "node-fetch": "^2.6.0",
    "nodemon": "^2.0.4",
    "qs": "^6.9.4",
    "uuid": "^8.2.0"
  }
}
